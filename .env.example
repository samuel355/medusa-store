NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Medusa Store API configuration. All three values are required by the
# storefront integration; obtain the key and region ID from the Medusa Admin.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_REGION_ID=
# Keep false until commerce-004 migrates checkout to the same Medusa cart.
NEXT_PUBLIC_MEDUSA_CART_ENABLED=true

# Direct Postgres connection to the Supabase project (used for all commerce data
# in the "medusastore" schema). Include ?options=-c%20search_path%3Dmedusastore
# in the connection string, or set DATABASE_SCHEMA and keep it in sync with client.ts.
DATABASE_URL=
DATABASE_SCHEMA=medusastore

PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

ARKESEL_API_KEY=
ARKESEL_SENDER_ID=

REDIS_URL=redis://localhost:6379
# Production example: rediss://default:<password>@<host>:6379

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
