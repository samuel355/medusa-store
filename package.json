{
  "name": "medusastore",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "backend:dev": "npm --prefix apps/backend run dev",
    "backend:build": "npm --prefix apps/backend run build",
    "backend:start": "npm --prefix apps/backend run start",
    "backend:seed": "npm --prefix apps/backend run seed",
    "lint": "eslint .",
    "test:unit": "node --import tsx --test src/lib/medusa/*.test.ts src/lib/medusa/catalogue/*.test.ts src/lib/medusa/cart/*.test.ts src/lib/medusa/checkout/*.test.ts",
    "typecheck": "tsc --noEmit",
    "workers": "tsx --env-file=.env.local src/workers/index.ts",
    "workers:dev": "tsx watch --env-file=.env.local src/workers/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1088.0",
    "@medusajs/js-sdk": "^2.17.2",
    "@medusajs/types": "^2.17.2",
    "@paystack/inline-js": "^2.23.1",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "2.110.6",
    "bullmq": "5.80.5",
    "ioredis": "5.11.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
